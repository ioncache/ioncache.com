  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "sitemap-generator": "^8.5.1",
    "url-parse": ">=1.5.10"
  },
  "engines": {
    "node": ">=20"
  },
  "volta": {
    "node": "24.16.0",
    "npm": "11.17.0"
  }
