{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "insertFinalNewline": true,
  "printWidth": 80,
  "semi": true,
  "singleQuote": true,
  "sortPackageJson": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false,
  "ignorePatterns": ["package-lock.json", "dist", "node_modules"]
}
